# Build-time escape hatch. Leave empty to use the frontend same-origin /api proxy.
NEXT_PUBLIC_API_BASE_URL=

# Local frontend against a local backend.
BACKEND_API_BASE_URL=http://localhost:8000
PUBLIC_WS_BASE_URL=ws://localhost:8000

# Local frontend against a backend VM.
# BACKEND_API_BASE_URL=http://<backend-vm-ip-or-domain>:8000
# PUBLIC_WS_BASE_URL=ws://<backend-vm-ip-or-domain>:8000

# Local frontend against a TLS backend.
# BACKEND_API_BASE_URL=https://<backend-domain>
# PUBLIC_WS_BASE_URL=wss://<backend-domain>
